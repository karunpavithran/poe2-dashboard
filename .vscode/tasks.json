{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/server"
      },
      "isBackground": true,
      "presentation": {
        "group": "dev-servers",
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": {
        "owner": "server",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Server listening at"
        }
      }
    },
    {
      "label": "Start Client",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "dependsOn": ["Start Server"],
      "presentation": {
        "group": "dev-servers",
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "Open in Simple Browser",
      "type": "shell",
      "command": "echo ${input:openSimpleBrowser}",
      "dependsOn": ["Start Client"],
      "presentation": {
        "reveal": "never",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "Dev: Start All",
      "dependsOn": ["Open in Simple Browser"],
      "presentation": {
        "reveal": "never"
      },
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ],
  "inputs": [
    {
      "id": "openSimpleBrowser",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": "http://localhost:5173"
    }
  ]
}
